#!/usr/bin/env bash
# Generate bathymetric contour lines with non-uniform intervals.
#
# Upsamples the DEM 2x with cubicspline to eliminate grid stairstepping,
# generates contours at specific depth levels defined in config.sh, then
# applies Chaikin corner-cutting for naturally curved lines.
#
# Outputs an enriched FlatGeobuf file. Use scripts/build for tiled processing
# and PMTiles generation.
#
# Usage:
#   ./scripts/contour input.tif [output.fgb]

source "$(dirname "$0")/config.sh"
check_deps gdal_contour gdalwarp ogr2ogr

SCRIPT_DIR="$(dirname "$0")"
INPUT_TIF="${1:?Usage: contour input.tif [output.fgb]}"
OUTPUT_FGB="${2:-${WORK_DIR}/contours_enriched.fgb}"

# Set SLOPE_SMOOTH=1 to run slope-selective DEM smoothing before contouring.
# This blurs flat areas (ocean floor) while preserving detail in steep terrain.
# See scripts/smooth-dem for tuning parameters.
SKIP_SLOPE_SMOOTH="${SKIP_SLOPE_SMOOTH:-}"
SKIP_UPSAMPLE="${SKIP_UPSAMPLE:-}"
SKIP_CHAIKIN="${SKIP_CHAIKIN:-}"

log "Input DEM: ${INPUT_TIF}"

# ─── Step 1: Upsample DEM ────────────────────────────────────────────────────
UPSAMPLED="${OUTPUT_FGB%.fgb}_upsampled.tif"
if [[ -n "${SKIP_UPSAMPLE}" ]]; then
  UPSAMPLED="${INPUT_TIF}"
  log "Skipping upsample"
else
  upsample_dem "${INPUT_TIF}" "${UPSAMPLED}"
fi

# ─── Step 1b: Slope-selective DEM smoothing (optional) ───────────────────────
if [[ -z "${SKIP_SLOPE_SMOOTH}" ]]; then
  SMOOTHED="${OUTPUT_FGB%.fgb}_smoothed.tif"
  if cached "${SMOOTHED}"; then
    log "Smoothed DEM already exists"
  else
    rm -f "${SMOOTHED}"
    log "Applying slope-selective smoothing..."
    "${SCRIPT_DIR}/smooth-dem" "${UPSAMPLED}" "${SMOOTHED}"
  fi
  UPSAMPLED="${SMOOTHED}"
fi

# ─── Step 2: Generate contours at fixed levels ───────────────────────────────
CONTOURS_RAW="${OUTPUT_FGB%.fgb}_raw.fgb"

if cached "${CONTOURS_RAW}"; then
  log "Raw contours already exist"
else
  rm -f "${CONTOURS_RAW}"
  log "Generating contours..."
  gdal_contour -fl ${CONTOUR_LEVELS} -a depth_m -f FlatGeobuf \
    "${UPSAMPLED}" "${CONTOURS_RAW}"
  COUNT=$(ogrinfo -al -so "${CONTOURS_RAW}" 2>/dev/null | grep "Feature Count" | awk '{print $NF}')
  log "  → ${COUNT} features"
fi

# ─── Step 3: Smooth contour geometries (Chaikin) ─────────────────────────────
CONTOURS_SMOOTH="${OUTPUT_FGB%.fgb}_smooth.fgb"

if [[ -n "${SKIP_CHAIKIN}" ]]; then
  CONTOURS_SMOOTH="${CONTOURS_RAW}"
  log "Skipping Chaikin smoothing"
elif cached "${CONTOURS_SMOOTH}"; then
  log "Smoothed contours already exist"
else
  rm -f "${CONTOURS_SMOOTH}"
  log "Smoothing contour geometries..."
  python3 "${SCRIPT_DIR}/smooth-contours" \
    "${CONTOURS_RAW}" "${CONTOURS_SMOOTH}" 0.0002 5
fi

# ─── Step 4: Enrich attributes ───────────────────────────────────────────────
if cached "${OUTPUT_FGB}"; then
  log "Enriched contours already exist"
else
  rm -f "${OUTPUT_FGB}"
  log "Enriching contours..."
  # Clip to OSM water polygons if available, to remove any contours that fall
  # on land. This is more accurate than the depth_m < 0 filter alone.
  ogr2ogr -f FlatGeobuf "${OUTPUT_FGB}" "${CONTOURS_SMOOTH}" \
    -dialect sqlite \
    -sql "
      SELECT geometry, depth_m,
        CAST(-depth_m AS INTEGER) AS depth_abs_m
      FROM contour
      WHERE depth_m < 0
    "
  COUNT=$(ogrinfo -al -so "${OUTPUT_FGB}" 2>/dev/null | grep "Feature Count" | awk '{print $NF}')
  log "  → ${COUNT} ocean features"
fi

# Clean up intermediates
rm -f "${UPSAMPLED}" "${CONTOURS_RAW}" "${CONTOURS_SMOOTH}"

log "Contours: ${OUTPUT_FGB}"

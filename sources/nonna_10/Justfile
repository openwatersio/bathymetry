# CHS NONNA-10 (Canada, 10 m) — Chart Datum bathymetry. Run from pipelines/:  just ../sources/nonna_10/
# Same guest-API harvest as nonna_100 but NONNA_LEVEL=5 (RepresentationLevel 5 = NONNA 10 m,
# 0.1° tiles). No static URLs; harvests tiles for a BBOX (defaults to Canada). EPSG:4326;
# elevation on Chart Datum (seafloor negative, like GEBCO) → no datum transform. Sibling of
# nonna_100 (cudem/cudem_third pattern): nonna_10 (z13) wins where it has data, nonna_100
# fills the rest. NOTE: a national 10 m harvest is hundreds of GB — scope by BBOX for real builds.
[no-cd]
default:
    NONNA_LEVEL=5 BBOX="${BBOX:--141,41,-53,84}" uv run python source_download_nonna.py nonna_10
    uv run python source_normalize.py nonna_10 --crs EPSG:4326
    uv run python source_bounds.py nonna_10
    uv run python source_polygonize.py nonna_10 8
    uv run python source_create_tarball.py nonna_10
